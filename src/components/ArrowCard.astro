---
import type { CollectionEntry } from "astro:content";

type Entry = CollectionEntry<"blog"> | CollectionEntry<"projects">;

type Props =
  | {
      entry: Entry;
      href?: never;
      title?: never;
      description?: never;
    }
  | {
      entry?: never;
      href: string;
      title: string;
      description: string;
      target?: string;
      rel?: string;
    };

const { entry, href, title, description, target, rel } = Astro.props as Props;
const cardHref = entry
  ? `/${entry.collection}/${entry.slug}`
  : href;
const cardTitle = entry ? entry.data.title : title;
const cardDescription = entry
  ? entry.data.description
  : description;
---

<a href={cardHref} target={target} rel={rel} class="relative group flex flex-nowrap py-3 px-4 pr-10 rounded-lg border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 text-black/50 dark:text-white/75 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out no-underline decoration-transparent">
  <div class="flex flex-col flex-1 truncate">
    <div class="font-semibold">
      {cardTitle}
    </div>
    <div class="text-sm">
      {cardDescription}
    </div>
  </div>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    viewBox="0 0 24 24"
    class="absolute top-1/2 right-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current">
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
    <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
  </svg>
</a>
