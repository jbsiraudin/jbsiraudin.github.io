---
type Props = {
  images: string[];
};

const { images } = Astro.props;
const count = images.length;
---

{count === 1 && (
  <div class="mosaic-root">
    <img src={images[0]} alt="" class="mosaic-img" />
  </div>
)}

{count === 2 && (
  <div class="mosaic-root mosaic-col">
    <img src={images[0]} alt="" class="mosaic-img" />
    <img src={images[1]} alt="" class="mosaic-img" />
  </div>
)}

{count === 3 && (
  <div class="mosaic-root mosaic-row">
    <img src={images[0]} alt="" class="mosaic-img mosaic-big" />
    <div class="mosaic-col">
      <img src={images[1]} alt="" class="mosaic-img" />
      <img src={images[2]} alt="" class="mosaic-img" />
    </div>
  </div>
)}

{count >= 4 && (
  <div class="mosaic-root mosaic-grid">
    {images.slice(0, 4).map((src) => (
      <img src={src} alt="" class="mosaic-img" />
    ))}
  </div>
)}

<style>
  .mosaic-root {
    width: 160px;
    min-width: 160px;
    height: 100%;
    min-height: 72px;
    overflow: hidden;
    border-radius: 0.5rem 0 0 0.5rem;
    display: flex;
  }

  .mosaic-col {
    flex-direction: column;
  }

  .mosaic-row {
    flex-direction: row;
  }

  .mosaic-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }

  .mosaic-img {
    flex: 1;
    min-width: 0;
    min-height: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mosaic-big {
    flex: 1.5;
  }
</style>
