---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { TOOLS } from "@consts";

const tools = [
  {
    title: "Timeliner",
    description:
      "Create images of video editing timelines from Premiere Pro and Final Cut Pro XML exports.",
    href: "/timeliner",
  },
  {
    title: "Alexandrin",
    description:
      "An editor to write classical verses in alexandrins with syllable counting.",
    href: "/alexandrin",
  },
];
---

<PageLayout title={TOOLS.TITLE} description={TOOLS.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white">
        Tools
      </div>
      <ul class="animate flex flex-col gap-4">
        {
          tools.map((tool) => (
            <li>
              <ArrowCard
                href={tool.href}
                title={tool.title}
                description={tool.description}
              />
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</PageLayout>
