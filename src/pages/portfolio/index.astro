---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import PortfolioCard from "@components/PortfolioCard.astro";
import { PORTFOLIO } from "@consts";

const projects = (await getCollection("projects"))
  .filter(portfolio => !portfolio.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const miscCollection = (await getCollection("misc"))
  .filter(item => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const misc = await Promise.all(
  miscCollection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);
---

<PageLayout title={PORTFOLIO.TITLE} description={PORTFOLIO.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white">
        Projects
      </div>
      <ul class="animate flex flex-col gap-4">
        {
          projects.map((project) => (
            <li>
              <PortfolioCard entry={project}/>
            </li>
          ))
        }
      </ul>
      <div class="animate font-semibold text-black dark:text-white">
        Misc
      </div>
      <ul class="flex flex-col space-y-10">
        {
          misc.map(entry => (
            <li class="animate">
              <div class="font-semibold text-black dark:text-white">
                {entry.data.demoURL
                  ? <a href={entry.data.demoURL} target="_blank" rel="noopener noreferrer" class="hover:underline">{entry.data.title}</a>
                  : entry.data.title
                }
              </div>
              <div class="text-sm opacity-75">{entry.data.description}</div>
              <article class="mt-4">
                <entry.Content />
              </article>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</PageLayout>
