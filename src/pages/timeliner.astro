---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Tutorial from "@components/Timeliner/Tutorial.astro";
import { Timeliner as TimelineEditor } from "@components/Timeliner/Timeliner.jsx";
---

<PageLayout title="Timeliner" description="A tool to create images of video editing timelines from Final Cut Pro XML exports.">
  <Container>
    <div class="space-y-4">
      <div class="font-semibold text-black dark:text-white">
        Timeliner
      </div>
      <p class="text-sm text-black/50 dark:text-white/50 leading-relaxed max-w-lg">
        Generates a visual image of a video editing timeline from a video editing software XML export. Useful for sharing the structure of a cut at a glance.
      </p>
      <Tutorial />
    </div>
  </Container>
  <TimelineEditor client:only="react" />
</PageLayout>
